DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dingdrop"
SESSION_SECRET="replace-with-a-long-random-secret"
APP_BASE_URL="http://localhost:3000"
PRISMA_LOG_QUERIES="false"
MAX_WEBHOOK_BODY_BYTES="1048576"
INBOX_QUERY_LIMIT="500"
REPLAY_TIMEOUT_MS="10000"
REPLAY_ALLOWED_HEADERS="content-type,user-agent"
ENABLE_MONITORS_UI="false"
ENABLE_PROBE_SCHEDULER="false"
ENABLE_PROBE_WORKER="false"
ENABLE_NOTIFICATIONS="false"
PROBE_EXECUTOR="blackbox"
BLACKBOX_BASE_URL="http://blackbox-exporter:9115"
BLACKBOX_HTTP_MODULE="http_2xx"
MONITOR_CHANNEL_SECRET="replace-with-a-long-random-secret"
PROBE_SNIPPET_MAX_BYTES="4096"
SCHEDULER_TICK_MS="10000"
MONITOR_INTERVAL_MIN_SEC="60"
ALERT_OPEN_FAILURES="3"
ALERT_RESOLVE_SUCCESSES="2"
ALERT_COOLDOWN_MINUTES="15"
MAX_MONITORS_PER_ORG="100"
MAX_QUEUED_JOBS_PER_ORG="500"
PROBE_RUN_RETENTION_DAYS="30"
NOTIFICATION_EVENT_RETENTION_DAYS="90"
