# Supabase connection pooler (Supavisor, session mode) — used by Prisma Client at runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
# Direct connection — used by Prisma for migrations (prisma migrate / db push)
DIRECT_URL="postgresql://postgres:[DB_PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
SESSION_SECRET="replace-with-a-long-random-secret"
APP_BASE_URL="http://localhost:3000"
PRISMA_LOG_QUERIES="false"
ENABLE_MONITORS_UI="false"
ENABLE_PROBE_SCHEDULER="false"
ENABLE_PROBE_WORKER="false"
ENABLE_NOTIFICATIONS="false"
DEBUG_VERBOSE="false"
PROBE_EXECUTOR="blackbox"
# Local dev: http://localhost:9115 (Docker Compose port mapping)
# Production/K8s: http://blackbox-exporter:9115 (container-to-container)
BLACKBOX_BASE_URL="http://localhost:9115"
BLACKBOX_HTTP_MODULE="http_2xx"
MONITOR_CHANNEL_SECRET="replace-with-a-long-random-secret"
# Optional: Resend API for email notifications (get from https://resend.com)
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="alerts@ding.ing"
PROBE_SNIPPET_MAX_BYTES="4096"
SCHEDULER_TICK_MS="10000"
MONITOR_INTERVAL_MIN_SEC="60"
ALERT_OPEN_FAILURES="3"
ALERT_RESOLVE_SUCCESSES="2"
ALERT_COOLDOWN_MINUTES="15"
MAX_MONITORS_PER_ORG="100"
MAX_QUEUED_JOBS_PER_ORG="500"
PROBE_RUN_RETENTION_DAYS="30"
NOTIFICATION_EVENT_RETENTION_DAYS="90"
